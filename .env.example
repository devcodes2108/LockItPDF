ENV=production
DATABASE_URL=postgresql://lockitpdf:replace-with-user-password@db.internal:5432/lockitpdf
SESSION_SECRET=replace-with-random-32-byte-secret
JWT_SECRET=replace-with-random-32-byte-secret-if-jwts-are-enabled
FRONTEND_ORIGIN=https://your-domain.example
APP_BASE_URL=https://your-domain.example
LOCKITPDF_ADMIN_EMAIL=dsinghwrites2108@gmail.com
LOCKITPDF_DATA_DIR=/var/lib/lockitpdf
LOCKITPDF_SESSION_TTL=2592000
LOCKITPDF_TOKEN_TTL=3600
LOCKITPDF_JOB_TTL=604800
LOCKITPDF_MAX_UPLOAD_MB=20
LOCKITPDF_FAILED_LOGIN_LIMIT=5
LOCKITPDF_LOCKOUT_SECONDS=900
LOCKITPDF_CAPTCHA_FAILURE_THRESHOLD=3
LOCKITPDF_CAPTCHA_ON_SIGNUP=false
LOCKITPDF_CAPTCHA_SECRET=replace-with-captcha-secret
LOCKITPDF_ALERT_WEBHOOK_URL=https://monitoring.example.invalid/webhook
LOCKITPDF_AV_SCANNER=clamav
REQUIRE_EMAIL_VERIFICATION=true
COOKIE_SECURE=true
RATELIMIT_STORAGE_URI=memory://
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=dsinghwrites2108@gmail.com
SMTP_PASS=replace-with-gmail-app-password
SMTP_FROM=dsinghwrites2108@gmail.com
